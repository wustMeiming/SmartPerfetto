# Model & Agent Tuning (optional)
# AGENT_MAX_TURNS=100
# AGENT_QUICK_MAX_TURNS=50
# CLAUDE_MAX_TURNS=100
# CLAUDE_QUICK_MAX_TURNS=50
# CLAUDE_FULL_PER_TURN_MS=60000
# CLAUDE_QUICK_PER_TURN_MS=40000
# CLAUDE_VERIFIER_TIMEOUT_MS=60000
# CLAUDE_CLASSIFIER_TIMEOUT_MS=30000
# OPENAI_MAX_TURNS=100
# OPENAI_QUICK_MAX_TURNS=50
# OPENAI_FULL_PER_TURN_MS=60000
# OPENAI_QUICK_PER_TURN_MS=40000
# OPENAI_CLASSIFIER_TIMEOUT_MS=30000
# AGENT_TERMINAL_SESSION_MAX_IDLE_MS=43200000
# AGENT_NON_TERMINAL_SESSION_MAX_IDLE_MS=43200000
# AGENT_SESSION_CONTEXT_MAX_AGE_MS=43200000
# AGENT_SESSION_CLEANUP_INTERVAL_MS=1800000
# SMARTPERFETTO_OUTPUT_LANGUAGE=zh-CN

# Claude Agent SDK Native Binary (advanced; rarely needed)
# The SDK ships a per-platform native `claude` binary as optional dependencies.
# It auto-selects via Node's glibc/musl detection at runtime. If detection
# misfires inside a container, you may see:
#   "Claude Code native binary not found at .../claude-agent-sdk-linux-x64-musl/claude"
# The backend now auto-detects an installed sibling variant. If it still picks
# wrong (e.g. multiple variants installed), point this env at the actual binary:
# CLAUDE_BINARY_PATH=/app/backend/node_modules/@anthropic-ai/claude-agent-sdk-linux-x64/claude
# Inspect what is actually installed:
#   docker exec -it <container> ls /app/backend/node_modules/@anthropic-ai/

# ---------------------------------------------------
# File Upload
# ---------------------------------------------------
MAX_FILE_SIZE=2147483648
UPLOAD_DIR=./uploads

# Perfetto Configuration (optional - uses default paths if not set)
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell
# PERFETTO_PATH=/path/to/perfetto

# Agent feature flags
FEATURE_AGENT_SCENE_RECONSTRUCT=true
FEATURE_AGENT_LOGS_API=true

# ADB full-mode guard (default false). Requires this flag AND per-request allowAgentFullMode=true.
SMARTPERFETTO_ALLOW_AGENT_ADB_FULL_MODE=false
